{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
   "scripts": {
    "dev": "concurrently -c \"green.bold,blue.bold,magenta.bold,yellow.bold,cyan.bold\" -n \"VUE,NODE,QUEUE,CRON,GOLD\" \"vite\" \"cd ../socket-server && node server.js\" \"cd ../backend && php artisan queue:work\" \"cd ../backend && php artisan schedule:work\" \"cd ../backend && php artisan sora:crawl-gold\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },

  "dependencies": {
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "moment": "^2.30.1",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "sweetalert2": "^11.26.22",
    "swiper": "^12.1.3",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
